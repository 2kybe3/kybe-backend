[wolfram_alpha]
enabled = false
token = "APP_ID"

[discord_bot]
enable = false
token = "DISCORD_TOKEN"
admin_id = "921066050009833572"

[discord_bot.translator]
enabled = false
url = "https://translate.kybe.xyz"
token = ""

[webserver]
behind_proxy = false
proxy_ip = "10.0.4.2"
api_token = "CHANGE_ME"
proxy_header = "X-Forwarded-For"
behind_i2p = false
i2p_ip = ""
i2p_header = "X-I2P-DestHash"

[webserver.umami]
script_path = "https://kybe.xyz/script.js"
id = "umami-id"

[maxmind]
city_enable = false
city_db_check = false
city = "./config/GeoLite2-City.mmdb"
asn_enable = false
asn_db_check = false
asn = "./config/GeoLite2-ASN.mmdb"

[lastfm]
enable = false
token = ""
username = ""
interval_secs = 10

[logger]
file_logger_enabled = true
